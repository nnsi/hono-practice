# バックエンド設定
API_PORT=3456
APP_URL=http://localhost:1357
DATABASE_URL=postgresql://user:password@host:port/dbname
JWT_SECRET=your-jwt-secret-key-here-must-be-at-least-32-characters
NODE_ENV=development
GOOGLE_OAUTH_CLIENT_ID=dummy-string

# フロントエンド設定（開発時）
VITE_PORT=1357
VITE_API_URL=http://localhost:3456
VITE_API_PORT=3456
VITE_CONTACT_EMAIL=
# 特商法表記の販売事業者氏名（法人の場合は名称）。特商法11条1号により個人事業主の氏名は常時表示必須。
VITE_ADMINISTRATOR_NAME=
# Web課金（Polar経由）を有効にする場合のみ "true"。false時は特商法ページ・アップグレード導線を非表示にする。
VITE_ENABLE_WEB_SUBSCRIPTION=false

# モバイル設定（開発時）
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_API_PORT=3456
EXPO_PUBLIC_CONTACT_EMAIL=
# 特商法表記の販売事業者氏名（EAS では `eas env:create` で登録する）
EXPO_PUBLIC_ADMINISTRATOR_NAME=

# git worktreeで並行開発する場合の例:
# メイン開発環境
# API_PORT=3456
# VITE_PORT=1357
# VITE_API_PORT=3456
# EXPO_PUBLIC_API_PORT=3456

# worktree 1
# API_PORT=3457
# VITE_PORT=5174
# VITE_API_PORT=3457
# EXPO_PUBLIC_API_PORT=3457

# worktree 2
# API_PORT=3458
# VITE_PORT=5175
# VITE_API_PORT=3458
# EXPO_PUBLIC_API_PORT=3458