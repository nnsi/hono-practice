{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/*.gen.ts",
      "!**/*.js",
      "!**/db-data",
      "!**/stats.html",
      "!.worktrees"
    ]
  },
  "formatter": {
    "formatWithErrors": true,
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              [
                "react",
                "react-dom",
                "react-dom/**",
                "react-router-dom",
                "hono",
                "hono/**"
              ],
              ":BLANK_LINE:",
              ":NODE:",
              ":BLANK_LINE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              ["@/**", "@frontend/**", "@backend/**", "@infra/**"],
              ":BLANK_LINE:",
              "@dtos/**",
              ":BLANK_LINE:",
              "@hooks/**",
              ":BLANK_LINE:",
              ["@components/ui", "@components/ui/**"],
              ":BLANK_LINE:",
              "@components/**",
              ":BLANK_LINE:",
              ":PATH:",
              ":BLANK_LINE:",
              { "type": true }
            ],
            "identifierOrder": "lexicographic"
          }
        }
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useSelfClosingElements": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off",
        "noUnusedVariables": "off"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConfusingVoidType": "off",
        "useIterableCallbackReturn": "off",
        "noUnknownAtRules": "off"
      },
      "complexity": {
        "noForEach": "off",
        "noBannedTypes": "off"
      },
      "a11y": {
        "useSemanticElements": "off",
        "noLabelWithoutControl": "off",
        "useKeyWithClickEvents": "off",
        "noStaticElementInteractions": "off",
        "noAutofocus": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@backend/*", "@frontend/*"],
                    "message": "packages/ から apps/ への逆方向import禁止。依存方向: apps → packages（ADR 20260225_domain_logic_to_packages）"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/frontend/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@backend/*"],
                    "message": "frontend から backend への直接import禁止。共有型は @packages/ 経由で参照する"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/backend/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@frontend/*"],
                    "message": "backend から frontend への直接import禁止。共有型は @packages/ 経由で参照する"
                  }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": false
    }
  }
}
