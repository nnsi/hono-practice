{
  "scripts": {
    "dev": "pnpm --filter actiko-backend --filter actiko-frontend --parallel dev",
    "dev:api": "pnpm --filter actiko-backend dev",
    "dev:fe": "pnpm --filter actiko-frontend dev",
    "dev:admin": "pnpm --filter actiko-admin-frontend dev",
    "test": "vitest --disable-console-intercept",
    "test-once": "vitest run",
    "test-e2e": "vitest run --config vitest.e2e.config.ts",
    "ci-check": "vitest run --reporter=dot && biome lint && pnpm run tsc",
    "tsc": "tsc --noEmit && pnpm --filter actiko-admin-frontend typecheck && pnpm --filter actiko-mobile typecheck",
    "lint": "biome lint",
    "fix": "biome check . --write --unsafe",
    "deploy:stg": "wrangler deploy --env stg",
    "deploy:prod": "wrangler deploy --env production",
    "build-client-stg": "pnpm --filter actiko-frontend build-stg",
    "build-client": "pnpm --filter actiko-frontend build",
    "deploy:fe-stg": "cd apps/frontend && pnpm exec wrangler deploy --env stg",
    "deploy:fe-prod": "cd apps/frontend && pnpm exec wrangler deploy --env production",
    "deploy:tail-stg": "cd apps/tail-worker && pnpm exec wrangler deploy --env stg",
    "deploy:tail-prod": "cd apps/tail-worker && pnpm exec wrangler deploy --env production",
    "db-generate": "drizzle-kit generate --config=infra/drizzle/drizzle.config.ts",
    "db-migrate": "drizzle-kit migrate --config=infra/drizzle/drizzle.config.ts",
    "db-seed": "tsx scripts/seed-dev-data.ts",
    "db-clean": "tsx scripts/clean-db.ts",
    "gen-be": "node scripts/gen-be.js",
    "mobile": "pnpm --filter actiko-mobile"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "lefthook",
      "workerd"
    ],
    "overrides": {
      "drizzle-orm>expo-sqlite": "-",
      "hono": "4.12.3",
      "miniflare>sharp": "-",
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@electric-sql/pglite": "^0.3.15",
    "@hono/node-server": "^1.19.9",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.44.7",
    "jsdom": "^26.1.0",
    "lefthook": "^1.10.1",
    "playwright": "^1.58.2",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5",
    "ts-mockito": "^2.6.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^6.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9",
    "wrangler": "^4.26.1"
  },
  "dependencies": {
    "@expo/plist": "^0.5.2",
    "i18next": "^25.10.10",
    "react-i18next": "^16.6.6"
  }
}
