{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/scripts/cc-log-to-md.js \"$transcript_path\" -o $CLAUDE_PROJECT_DIR/docs/diary-cc-logs/$(date +%Y%m%d%H%M%S).md"
          }
        ]
      }
    ]
  }
}
