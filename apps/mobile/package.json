    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.12",
    "expo-web-browser": "~56.0.4",
    "hono": "^4.12.3",
    "lucide-react-native": "~0.575.0",
    "nativewind": "^4.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-marked": "^8.0.1",
    "react-native-purchases": "^9.14.0",
