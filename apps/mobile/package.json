{
  "name": "actiko-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "start:e2e": "EXPO_PUBLIC_E2E_MODE=1 EXPO_PUBLIC_API_URL_IOS=http://localhost:3536 EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2:3536 expo start --dev-client --clear --port 8082",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas": "dotenv -e .env -- eas",
    "e2e:smoke": "maestro test .maestro/smoke.yaml",
    "e2e:smoke:android": "maestro test .maestro/smoke.yaml",
    "e2e:smoke:ios": "maestro test .maestro/smoke.yaml",
    "typecheck": "tsgo --noEmit",
    "lint": "biome lint ./src",
    "test-once": "pnpm --dir ../.. exec vitest run --config vitest.config.ts apps/mobile"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@expo/dom-webview": "~56.0.5",
    "@expo/metro-runtime": "~56.0.8",
    "@expo/plist": "^0.5.2",
    "@packages/auth-client": "workspace:*",
    "@packages/domain": "workspace:*",
    "@packages/i18n": "workspace:*",
    "@packages/platform": "workspace:*",
    "@packages/sync-engine": "workspace:*",
    "@packages/types": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/react-query": "^5.90.21",
    "dayjs": "^1.11.13",
    "expo": "^56.0.0-preview.12",
    "expo-apple-authentication": "~56.0.3",
    "expo-auth-session": "~56.0.8",
    "expo-build-properties": "~56.0.9",
    "expo-constants": "~56.0.11",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.11",
    "expo-document-picker": "~56.0.3",
    "expo-file-system": "~56.0.5",
    "expo-image-manipulator": "~56.0.9",
    "expo-image-picker": "~56.0.9",
    "expo-linking": "~56.0.8",
    "expo-localization": "~56.0.4",
    "expo-router": "~56.2.1",
    "expo-secure-store": "~56.0.3",
