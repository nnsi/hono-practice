{
  "expo": {
    "name": "Actiko",
    "slug": "actiko",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "actiko",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.actiko.app"
    },
    "android": {
      "package": "com.actiko.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser",
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ad87f25-5808-4934-a5d1-7a532ab827df"
      }
    },
    "owner": "nnsi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7ad87f25-5808-4934-a5d1-7a532ab827df"
    }
  }
}
