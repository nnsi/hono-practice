{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "development:simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      }
    },
    "e2e-test": {
      "environment": "preview",
      "withoutCredentials": true,
      "env": {
        "EXPO_PUBLIC_E2E_MODE": "1"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "e2e-local-android": {
      "withoutCredentials": true,
      "env": {
        "ANDROID_USES_CLEARTEXT_TRAFFIC": "true",
        "EXPO_PUBLIC_API_URL_ANDROID": "http://10.0.2.2:3536",
        "EXPO_PUBLIC_E2E_MODE": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "e2e-local-ios": {
      "withoutCredentials": true,
      "env": {
        "EXPO_PUBLIC_API_URL_IOS": "http://localhost:3536",
        "EXPO_PUBLIC_E2E_MODE": "1"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  }
}
